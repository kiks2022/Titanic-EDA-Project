{"cells":[{"cell_type":"code","source":["from google.colab import drive\n","drive.mount('/content/drive')\n","import pandas as pd\n","\n","df = pd.read_csv('/content/drive/MyDrive/Colab Notebooks/Titanic Project/Titanic-Dataset.csv')\n","\n","print('Rows and columns:', df.shape)\n","df.head()\n","print('=== Shape (rows, columns) ===')\n","print(df.shape)\n","\n","print('\\n=== First 5 rows ===')\n","print(df.head())\n","\n","print('\\n=== Column info ===')\n","df.info()\n","\n","print('=== Missing values per column ===')\n","missing = df.isnull().sum()\n","missing_pct = (df.isnull().sum() / len(df) * 100).round(2)\n","\n","missing_df = pd.DataFrame({\n","    'Missing Count': missing,\n","    'Missing %': missing_pct\n","})\n","print(missing_df[missing_df['Missing Count'] > 0])\n","\n","print('Average age before:', df['Age'].mean().round(1))\n","\n","df['Age'].fillna(df['Age'].median(), inplace=True)\n","\n","print('Missing ages now:', df['Age'].isnull().sum())\n","print('✅ Age fixed!')\n","\n","print('Most common port:', df['Embarked'].mode()[0])\n","\n","df['Embarked'].fillna(df['Embarked'].mode()[0], inplace=True)\n","\n","print('Missing Embarked now:', df['Embarked'].isnull().sum())\n","print('✅ Embarked fixed!')\n","\n","# Instead of deleting it completely, we create a new column:\n","# 1 = passenger had a cabin number, 0 = they didn't\n","df['HasCabin'] = df['Cabin'].notna().astype(int)\n","df.drop(columns=['Cabin'], inplace=True)\n","\n","print('Cabin column removed.')\n","print('HasCabin column added.')\n","print('✅ Cabin fixed!')\n","\n","# PassengerId = just a row number, useless\n","# Name = everyone has a unique name, can't learn from it\n","# Ticket = random ticket codes, useless\n","\n","df.drop(columns=['PassengerId', 'Name', 'Ticket'], inplace=True)\n","\n","print('Remaining columns:', df.columns.tolist())\n","print('New shape:', df.shape)\n","\n","print('Missing values remaining:')\n","print(df.isnull().sum())\n","print('\\n✅ Dataset is clean!')\n","df.head()\n","\n","df.to_csv('/content/drive/MyDrive/cleaned_titanic.csv', index=False)\n","print('✅ Cleaned file saved to your Google Drive!')\n","\n","import matplotlib.pyplot as plt\n","import seaborn as sns\n","\n","sns.set_theme(style='whitegrid')\n","plt.rcParams['figure.figsize'] = (8, 5)\n","print('✅ Ready to make charts!')\n","\n","survival_counts = df['Survived'].value_counts()\n","\n","plt.figure()\n","plt.bar(['Did NOT survive', 'Survived'],\n","        survival_counts.values,\n","        color=['#E24B4A', '#1D9E75'],\n","        edgecolor='white', width=0.5)\n","\n","plt.title('How many passengers survived?', fontsize=14, fontweight='bold')\n","plt.ylabel('Number of passengers')\n","\n","for i, v in enumerate(survival_counts.values):\n","    plt.text(i, v + 5, str(v), ha='center', fontweight='bold')\n","\n","plt.tight_layout()\n","plt.savefig('/content/drive/MyDrive/chart1_survival.png', dpi=150)\n","plt.show()\n","\n","rate = df['Survived'].mean() * 100\n","print(f'Survival rate: {rate:.1f}% of passengers survived')\n","\n","gender_survival = df.groupby('Sex')['Survived'].mean() * 100\n","\n","plt.figure()\n","bars = plt.bar(['Male', 'Female'],\n","               gender_survival.values,\n","               color=['#378ADD', '#D4537E'],\n","               edgecolor='white', width=0.5)\n","\n","plt.title('Survival rate by gender', fontsize=14, fontweight='bold')\n","plt.ylabel('Survival rate (%)')\n","plt.ylim(0, 100)\n","\n","for bar, val in zip(bars, gender_survival.values):\n","    plt.text(bar.get_x() + bar.get_width()/2,\n","             val + 2, f'{val:.1f}%', ha='center', fontweight='bold')\n","\n","plt.tight_layout()\n","plt.savefig('/content/drive/MyDrive/chart2_gender.png', dpi=150)\n","plt.show()\n","\n","plt.figure()\n","sns.histplot(data=df, x='Age', hue='Survived', bins=30,\n","             palette={0: '#E24B4A', 1: '#1D9E75'}, alpha=0.7)\n","\n","plt.title('Age of survivors vs non-survivors', fontsize=14, fontweight='bold')\n","plt.xlabel('Age')\n","plt.ylabel('Number of passengers')\n","plt.legend(['Did not survive', 'Survived'])\n","\n","plt.tight_layout()\n","plt.savefig('/content/drive/MyDrive/chart4_age.png', dpi=150)\n","plt.show()\n","\n","import numpy as np\n","\n","# Convert Sex and Embarked to numbers first\n","df_numeric = df.copy()\n","df_numeric['Sex'] = df_numeric['Sex'].map({'male': 0, 'female': 1})\n","df_numeric['Embarked'] = df_numeric['Embarked'].map({'S': 0, 'C': 1, 'Q': 2})\n","\n","plt.figure(figsize=(9, 6))\n","corr = df_numeric.corr(numeric_only=True)\n","mask = np.triu(np.ones_like(corr, dtype=bool))\n","\n","sns.heatmap(corr, mask=mask, annot=True, fmt='.2f',\n","            cmap='RdYlGn', center=0, vmin=-1, vmax=1,\n","            square=True, linewidths=0.5)\n","\n","plt.title('Which columns relate to survival?', fontsize=14, fontweight='bold')\n","plt.tight_layout()\n","plt.savefig('/content/drive/MyDrive/chart5_heatmap.png', dpi=150)\n","plt.show()\n","\n","print(\"\"\"\n","╔══════════════════════════════════════════════════════╗\n","║     TITANIC DATASET — SUMMARY OF INSIGHTS            ║\n","║     AnalystLab Africa AI Internship Week 1 & 2       ║\n","╚══════════════════════════════════════════════════════╝\n","\n","DATASET OVERVIEW\n","─────────────────\n","- Total passengers : 891\n","- Total columns    : 12 (cleaned down to 9)\n","- Survival rate    : 38.4% survived, 61.6% did not\n","\n","DATA CLEANING\n","─────────────────\n","- Age   : 177 missing values → filled with median age (28)\n","- Cabin : 687 missing (77%) → replaced with HasCabin column\n","- Embarked : 2 missing → filled with most common port (S)\n","- Dropped  : PassengerId, Name, Ticket (not useful)\n","\n","KEY FINDINGS FROM CHARTS\n","─────────────────\n","- GENDER   : Women survived at ~74%, men at only ~19%\n","             → \"Women and children first\" was real!\n","\n","- CLASS    : 1st class ~63% survived\n","             2nd class ~47% survived\n","             3rd class ~24% survived\n","             → Richer passengers had better access to lifeboats\n","\n","- AGE      : Children under 10 had higher survival rates\n","             → Young children were prioritised for rescue\n","\n","- HEATMAP  : Sex and Pclass are the strongest predictors\n","             of whether a passenger survived\n","\n","CONCLUSION\n","─────────────────\n","Your wealth and your gender determined whether you lived\n","or died on the Titanic. Being a woman in 1st class gave\n","you the best chance. Being a man in 3rd class gave you\n","the worst.\n","\"\"\")\n","\n","import os\n","import shutil\n","\n","# Your exact folder path\n","folder = '/content/drive/MyDrive/Colab Notebooks/Titanic Project'\n","\n","# Create it if it doesn't exist yet\n","os.makedirs(folder, exist_ok=True)\n","print('✅ Folder ready: Colab Notebooks/Titanic Project')\n","\n","# List of files to move\n","files = [\n","    'cleaned_titanic.csv',\n","    'chart1_survival.png',\n","    'chart2_gender.png',\n","    'chart3_class.png',\n","    'chart4_age.png',\n","    'chart5_heatmap.png',\n","    'titanic_summary.txt'\n","]\n","\n","# Move each file\n","for f in files:\n","    src = f'/content/drive/MyDrive/{f}'\n","    dst = f'{folder}/{f}'\n","    if os.path.exists(src):\n","        shutil.move(src, dst)\n","        print(f'✅ Moved: {f}')\n","    else:\n","        print(f'❌ Not found: {f}')\n","\n","print('\\nAll files are now in: My Drive/Colab Notebooks/Titanic Project')\n","\n","# Recreate chart3 and save directly to the right folder\n","folder = '/content/drive/MyDrive/Colab Notebooks/Titanic Project'\n","\n","# Chart 3 — Survival by class\n","class_survival = df.groupby('Pclass')['Survived'].mean() * 100\n","\n","plt.figure()\n","bars = plt.bar(['1st Class\\n(Rich)', '2nd Class\\n(Middle)', '3rd Class\\n(Poor)'],\n","               class_survival.values,\n","               color=['#EF9F27', '#888780', '#5DCAA5'],\n","               edgecolor='white', width=0.5)\n","\n","plt.title('Survival rate by passenger class', fontsize=14, fontweight='bold')\n","plt.ylabel('Survival rate (%)')\n","plt.ylim(0, 100)\n","\n","for bar, val in zip(bars, class_survival.values):\n","    plt.text(bar.get_x() + bar.get_width()/2,\n","             val + 2, f'{val:.1f}%', ha='center', fontweight='bold')\n","\n","plt.tight_layout()\n","plt.savefig(f'{folder}/chart3_class.png', dpi=150)\n","plt.show()\n","print('✅ chart3_class.png saved!')\n","\n","# Recreate summary text file\n","summary = \"\"\"\n","TITANIC DATASET - SUMMARY OF INSIGHTS\n","AnalystLab Africa AI Internship Week 1 & 2\n","\n","DATASET OVERVIEW\n","Total passengers : 891\n","Total columns    : 12 (cleaned down to 9)\n","Survival rate    : 38.4% survived, 61.6% did not\n","\n","DATA CLEANING\n","Age     : 177 missing values filled with median age (28)\n","Cabin   : 687 missing (77%) replaced with HasCabin column\n","Embarked: 2 missing filled with most common port (S)\n","Dropped : PassengerId, Name, Ticket (not useful)\n","\n","KEY FINDINGS\n","Gender : Women survived at 74%, men at only 19%\n","Class  : 1st class 63%, 2nd class 47%, 3rd class 24%\n","Age    : Children under 10 had higher survival rates\n","Heatmap: Sex and Pclass are strongest predictors of survival\n","\n","CONCLUSION\n","Your wealth and gender determined whether you lived or died.\n","Being a woman in 1st class = best chance of survival.\n","Being a man in 3rd class = worst chance of survival.\n","\"\"\"\n","\n","with open(f'{folder}/titanic_summary.txt', 'w') as f:\n","    f.write(summary)\n","print('✅ titanic_summary.txt saved!')\n","\n","# Feature Encoding\n","# Convert Sex and Embarked from text into numbers\n","# ML models only understand numbers, not words like \"male\" or \"female\"\n","\n","from sklearn.preprocessing import LabelEncoder\n","\n","le = LabelEncoder()\n","\n","df['Sex_encoded'] = le.fit_transform(df['Sex'])\n","# male = 0, female = 1\n","\n","df['Embarked_encoded'] = le.fit_transform(df['Embarked'])\n","# S = 2, C = 0, Q = 1\n","\n","print('=== Feature Encoding ===')\n","print('Sex encoded:')\n","print(df[['Sex', 'Sex_encoded']].drop_duplicates())\n","print('\\nEmbarked encoded:')\n","print(df[['Embarked', 'Embarked_encoded']].drop_duplicates())\n","\n","# Data Scaling\n","# Age ranges from 0-80, Fare ranges from 0-500\n","# Scaling brings them to the same range so one doesnt dominate the other\n","\n","from sklearn.preprocessing import StandardScaler\n","\n","scaler = StandardScaler()\n","\n","df[['Age_scaled', 'Fare_scaled']] = scaler.fit_transform(df[['Age', 'Fare']])\n","\n","print('=== Data Scaling ===')\n","print('Before scaling:')\n","print(f'Age  — min: {df[\"Age\"].min():.1f}, max: {df[\"Age\"].max():.1f}')\n","print(f'Fare — min: {df[\"Fare\"].min():.1f}, max: {df[\"Fare\"].max():.1f}')\n","\n","print('\\nAfter scaling:')\n","print(f'Age  — min: {df[\"Age_scaled\"].min():.2f}, max: {df[\"Age_scaled\"].max():.2f}')\n","print(f'Fare — min: {df[\"Fare_scaled\"].min():.2f}, max: {df[\"Fare_scaled\"].max():.2f}')\n","\n","print('\\n✅ Scaling done! Everything is now on the same scale.')\n","\n","folder = '/content/drive/MyDrive/Colab Notebooks/Titanic Project'\n","\n","df.to_csv(f'{folder}/cleaned_titanic_final.csv', index=False)\n","print('✅ Final cleaned dataset saved!')\n","print('Columns:', df.columns.tolist())\n","\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"0jOpPVQ3XUj5","executionInfo":{"status":"ok","timestamp":1780775148279,"user_tz":420,"elapsed":42978,"user":{"displayName":"Lomo Adekoya","userId":"01505174115513412101"}},"outputId":"8c2836b3-dd56-4ee5-e77c-e1899740a8bd"},"execution_count":2,"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n","Rows and columns: (891, 12)\n","=== Shape (rows, columns) ===\n","(891, 12)\n","\n","=== First 5 rows ===\n","   PassengerId  Survived  Pclass  \\\n","0            1         0       3   \n","1            2         1       1   \n","2            3         1     